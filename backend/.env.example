# Database connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/datapulse

# Express API Port
PORT=3001

# Polling concurrency limit (optional: used to throttle worker checks if implemented)
MAX_CONCURRENT_CHECKS=10

# Default webhook URL for testing local alerts (optional)
# DEFAULT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_CHANNEL/YOUR_TOKEN
